{
  "name": "ifinmail-desktop",
  "version": "0.1.0",
  "description": "ifinmail Desktop Client – Cross-platform email client",
  "homepage": "https://ifinmail.local",
  "author": "ifinmail <dev@ifinmail.local>",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "ELECTRON_DEV=1 electron .",
    "build:linux": "electron-builder --linux AppImage deb",
    "build:mac": "electron-builder --mac dmg",
    "build:win": "electron-builder --win nsis",
    "build:all": "electron-builder --linux AppImage deb --mac dmg --win nsis"
  },
  "build": {
    "appId": "com.ifinmail.desktop",
    "productName": "ifinmail",
    "directories": {
      "output": "dist"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "assets/icon.png",
      "category": "Network",
      "maintainer": "ifinmail <dev@ifinmail.local>"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "assets/icon.icns",
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": ["nsis"],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "main.js",
      "preload.js",
      "assets/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "electron-updater": "^6.0.0",
    "electron-store": "^10.0.0"
  }
}
