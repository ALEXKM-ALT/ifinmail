# ifinmail environment variables — copy to .env and fill in values
# Generated by provision.sh — do not commit .env to version control

# Django
DJANGO_SECRET_KEY=
DJANGO_SETTINGS_MODULE=backend.config.settings.production
ALLOWED_HOSTS=
DJANGO_ALLOWED_HOSTS=

# Database
DB_NAME=ifinmail
DB_USER=ifinmail_app
DB_PASSWORD=
DB_HOST=postgres
DB_PORT=5432
DB_SSLMODE=require
DATABASE_URL=postgresql://ifinmail_app:PASSWORD@postgres:5432/ifinmail?sslmode=require

# Redis
REDIS_URL=redis://:PASSWORD@redis:6379/0
REDIS_PASSWORD=
REDIS_HOST=redis
REDIS_PORT=6379
CELERY_BROKER_URL=redis://:PASSWORD@redis:6379/1

# Email / Mail
MAIL_DOMAIN=example.com
MAIL_HOSTNAME=mail.example.com

# Admin
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=

# Security
CSRF_TRUSTED_ORIGINS=https://example.com,https://mail.example.com
CORS_ALLOWED_ORIGINS=
AXES_FAILURE_LIMIT=5
SECURE_HSTS_SECONDS=3600

# Sentry (optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# Database roles
POSTGRES_ADMIN_PASSWORD=
APP_DB_PASSWORD=
DOVECOT_DB_PASSWORD=
POSTFIX_DB_PASSWORD=

# Monitoring
MONITOR_ALERT_WEBHOOK=
MONITOR_QUEUE_WARN=50
MONITOR_QUEUE_CRITICAL=200
MONITOR_CERT_WARN_DAYS=30
MONITOR_CERT_CRITICAL_DAYS=7

# Backup
BACKUP_GPG_RECIPIENT=
BACKUP_RETENTION_DAYS=7
BACKUP_ENCRYPT=true
