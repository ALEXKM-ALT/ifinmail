# ───────────────────────────────────────────
# ifinmail Environment Configuration
# ───────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# ───────────────────────────────────────────

### Required (must be set in production) ###
IFINMAIL_SECRET_KEY=change-me-to-a-long-random-string
IFINMAIL_DB_PASSWORD=change-me-to-a-strong-password

### Database (default: local PostgreSQL) ###
# IFINMAIL_DATABASE_URL=postgresql://ifinmail:yourpassword@db:5432/ifinmail

### Redis (default: local Redis) ###
# IFINMAIL_REDIS_URL=redis://redis:6379/0

### Environment ###
# IFINMAIL_ENV=development
# IFINMAIL_LOG_LEVEL=INFO

### JWT Token Settings ###
# IFINMAIL_ACCESS_TOKEN_EXPIRE=1440
# IFINMAIL_REFRESH_TOKEN_EXPIRE=7

### Application URL (used in password reset emails) ###
# IFINMAIL_APP_URL=http://localhost:8000

### Outbound SMTP Relay (for sending email) ###
# IFINMAIL_SMTP_HOST=smtp.example.com
# IFINMAIL_SMTP_PORT=587
# IFINMAIL_SMTP_TLS=true
# IFINMAIL_SMTP_USER=noreply@yourdomain.com
# IFINMAIL_SMTP_PASSWORD=your-smtp-password
# IFINMAIL_SMTP_TIMEOUT=30

### SSO / Social Login (OAuth 2.0) ###
# Get Google credentials at https://console.cloud.google.com/apis/credentials
# SSO_GOOGLE_CLIENT_ID=your-google-client-id
# SSO_GOOGLE_CLIENT_SECRET=your-google-client-secret

# Get Microsoft credentials at https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
# SSO_MICROSOFT_CLIENT_ID=your-microsoft-client-id
# SSO_MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret

### Storage ###
# IFINMAIL_ATTACHMENT_STORAGE=~/.ifinmail/attachments
